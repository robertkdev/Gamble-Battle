			"max_by_cost": { "1": 3.5, "2": 3.5, "3": 3.5, "4": 3.5, "5": 3.5 },
			"relaxations": {
			  "peel": { "max_time_s": 4.0 }
			}
		  },
		  "cast_window_s": {
			"max_by_cost": { "1": 1.5, "2": 1.5, "3": 1.5, "4": 1.5, "5": 1.5 }
		  },
		  "cast_pre_signal_grace_s": {
			"max_by_cost": { "1": 0.1, "2": 0.1, "3": 0.1, "4": 0.1, "5": 0.1 }
		  }
		}
	  }
	},
	"marksman": {
	  "k_of_n": { "k": 2, "n": 2 },
	  "metrics": {
		"sustained_damage_rate": {
		  "comparison": {
			"median_multiplier": 1.25,
