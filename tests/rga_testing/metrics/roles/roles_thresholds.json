{
  "schema": {
	"version": "1.1.0",
	"notes": "Centralized per-role KPI thresholds by cost band with scenario relaxations. All tests must read from here (no magic numbers). Targets normalized for team EHP = 100 and team sustained DPS = 100 (≈24s mirror).",
	"cost_bands": [1, 2, 3, 4, 5],
	"scenarios": ["neutral", "peel", "burst"],
	"default_tolerance": 0.10
  },
  "targets": {
	"notes": "Role targets used for balancing guidance; included for reference in tests and reports.",
	"roles": {
	  "tank": { "ehp_share": 0.30, "sustained_dps_share": 0.06, "burst_share_first4s": 0.06, "focus_ttk_vs_150_dps_s": 12.0 },
	  "brawler": { "ehp_share": 0.20, "sustained_dps_share": 0.20, "burst_share_first4s": 0.16, "focus_ttk_vs_150_dps_s": 8.0 },
	  "marksman": { "ehp_share": 0.15, "sustained_dps_share": 0.30, "burst_share_first4s": 0.14, "focus_ttk_vs_150_dps_s": 6.0 },
	  "mage": { "ehp_share": 0.10, "sustained_dps_share": 0.24, "burst_share_first4s": 0.30, "focus_ttk_vs_150_dps_s": 5.0 },
	  "assassin": { "ehp_share": 0.10, "sustained_dps_share": 0.16, "burst_share_first4s": 0.30, "focus_ttk_vs_150_dps_s": 5.0 },
	  "support": { "ehp_share": 0.15, "sustained_dps_share": 0.04, "burst_share_first4s": 0.04, "focus_ttk_vs_150_dps_s": 7.0 }
	}
  },
  "roles": {
	"tank": {
	  "k_of_n": { "k": 2, "n": 2 },
	  "metrics": {
		"focus_survival_s": {
		  "min_by_cost": { "1": 12.0, "2": 12.0, "3": 12.0, "4": 12.0, "5": 12.0 },
		  "relaxations": {
			"burst": { "multiplier": 0.0, "offset": 2.0 }
		  },
		  "tolerance": 0.10
		},
		"soak_index": {
		  "min_by_cost": { "1": 0.55, "2": 0.55, "3": 0.55, "4": 0.55, "5": 0.55 },
		  "tolerance": 0.10
		},
		"damage_taken_total": {
		  "metric": "damage_taken_total",
		  "min_by_cost": { "1": 200.0, "2": 280.0, "3": 360.0, "4": 440.0, "5": 520.0 },
		  "tolerance": 0.10
		},
		"team_damage_share": {
		  "max_by_cost": { "1": 0.25, "2": 0.25, "3": 0.25, "4": 0.25, "5": 0.25 },
		  "tolerance": 0.10
		}
	  },
	  "fallback": {
		"time_alive_s": { "min_by_cost": { "1": 8.0, "2": 8.0, "3": 8.0, "4": 8.0, "5": 8.0 } }
	  }
	},
	"brawler": {
	  "k_of_n": { "k": 2, "n": 2 },
	  "metrics": {
		"can_take_damage": {
		  "notes": "Composite survivability target. Prefer focus/hits kernels; fall back to time alive when kernels are unavailable in fast smoke probes.",
		  "composite_any": [
			{ "metric": "focus_survival_s", "min_by_cost": { "1": 8.0, "2": 8.0, "3": 8.0, "4": 8.0, "5": 8.0 }, "tolerance": 0.10 },
			{ "metric": "hits_survived", "min_by_cost": { "1": 2.0, "2": 2.0, "3": 2.0, "4": 2.0, "5": 2.0 }, "tolerance": 0.10 }
		  ]
		},
		"sustained_damage_rate": {
		  "comparison": {
			"median_multiplier": 1.05,
			"z_min": 0.25
		  },
		  "min_by_cost": { "1": 1.05, "2": 1.05, "3": 1.05, "4": 1.10, "5": 1.10 },
		  "tolerance": 0.10
		},
		"damage_taken_total": { "metric": "damage_taken_total", "min_by_cost": { "1": 180.0, "2": 230.0, "3": 280.0, "4": 330.0, "5": 380.0 }, "tolerance": 0.10 }
	  },
	  "fallback": {
		"all": [
		  { "metric": "time_alive_s", "min_by_cost": { "1": 8.0, "2": 8.0, "3": 8.0, "4": 8.0, "5": 8.0 }, "tolerance": 0.10 }
		]
	  }
	},
	"assassin": {
	  "k_of_n": { "k": 1, "n": 1 },
