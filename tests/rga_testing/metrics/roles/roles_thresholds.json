	  "k_of_n": { "k": 1, "n": 2 },
	  "metrics": {
		"periodicity": {
		  "any": [
			{ "metric": "top_2s_magic_damage_share", "min_by_cost": { "1": 0.35, "2": 0.35, "3": 0.35, "4": 0.35, "5": 0.35 }, "tolerance": 0.10 },
			{ "metric": "magic_peak_over_mean", "min_by_cost": { "1": 1.7, "2": 1.7, "3": 1.7, "4": 1.7, "5": 1.7 }, "tolerance": 0.10 }
		  ]
